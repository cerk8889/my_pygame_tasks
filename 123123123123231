import pygame
import numpy  # !! понадобится ещё один модуль, установи его: pip install numpy
import random

FPS = 60
SCREEN_WIDTH = 600
SCREEN_HEIGHT = 900
BLOCK_SIZE = 50

BLACK = (0, 0, 0)
WHITE = (255, 255, 255)
COLORS = [
    (0, 255, 255),  # I
    (0, 0, 255),    # J
    (255, 165, 0),  # L
    (255, 255, 0),  # O
    (0, 255, 0),    # S
    (128, 0, 128),  # T
    (255, 0, 0)     # Z
]

FIGURES = [
    [[1, 1, 1, 1]],  # I

    [[1, 0, 0],
     [1, 1, 1]],     # J

    [[0, 0, 1],
     [1, 1, 1]],     # L

    [[1, 1],
     [1, 1]],        # O

    [[0, 1, 1],
     [1, 1, 0]],     # S

    [[0, 1, 0],
     [1, 1, 1]],     # T

    [[1, 1, 0],
     [0, 1, 1]]      # Z
]


class Figure:
    def __init__(self, x, y):
        self.y = y
        self.x = x
        self.type = random.randint(0, len(FIGURES) - 1)
        self.color = COLORS[self.type]
        self.shape = FIGURES[self.type].copy()

    def rotate(self):  # !!! полностью переписала этот метод, он поворачивает self.shape по часовой стрелке
        # например, было self.shape =
        # [[1, 0, 0],
        #  [1, 1, 1]]
        new_shape = self.shape.copy()
        new_shape = numpy.array(new_shape)
        new_shape = new_shape.T
        new_shape = new_shape[:, ::-1]
        new_shape = new_shape.tolist()
        self.shape = new_shape.copy()
        # тгд к этому моменту self.shape =
        # [[1, 1],
        #  [1, 0],
        #  [1, 0]]


class Tetris:
    def __init__(self, height, width):
        self.height = height
        self.width = width
        self.field = [[0 for _ in range(width)] for _ in range(height)]
        self.figure = None
        self.score = 0

    def new_figure(self):
        self.figure = Figure(self.width // 2 - 1, 0)

    def intersects(self):
        shape = self.figure.shape  # !!! теперь это не метод shape(), а свойство. см. выше конструктор класса Figure
        for y, row in enumerate(shape):
            for x, cell in enumerate(row):
                if cell:
                    if (self.figure.y + y >= self.height or self.figure.x + x < 0 or self.figure.x + x >= self.width
                            or self.field[self.figure.y + y][self.figure.x + x]):
                        return True
        return False

    def freeze(self):
        shape = self.figure.shape
        for y, row in enumerate(shape):
            for x, cell in enumerate(row):
                if cell:
                    self.field[self.figure.y + y][self.figure.x + x] = self.figure.color
        self.clear_lines()
        self.new_figure()
        if self.intersects():
            self.__init__(self.height, self.width)  # Game Over

    def clear_lines(self):
        lines_cleared = 0
        for i in range(self.height - 1, -1, -1):
            if all(self.field[i]):
                del self.field[i]
                self.field.insert(0, [0 for _ in range(self.width)])
                lines_cleared += 1
        self.score += lines_cleared ** 2


pygame.init()
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
screen.fill(WHITE)  # !!! на старте надо сделать заливку экрана
pygame.display.set_caption("Тетрис")
clock = pygame.time.Clock()
font = pygame.font.Font(None, 36)

game = Tetris(SCREEN_HEIGHT // BLOCK_SIZE, SCREEN_WIDTH // BLOCK_SIZE)
fall_speed = 500
last_move_down = pygame.time.get_ticks()

game.new_figure()

pygame.display.update()  #  !!! не забываем обновлять экран

running = True
while running:
    clock.tick(FPS)
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
            break  # !!! добавила прерывание цикла обработки событий for, если флаг running = False
        elif event.type == pygame.KEYDOWN:
            if event.key == pygame.K_LEFT:
                game.figure.x -= 1
                if game.intersects():
                    game.figure.x += 1
            elif event.key == pygame.K_RIGHT:
                game.figure.x += 1
                if game.intersects():
                    game.figure.x -= 1
            elif event.key == pygame.K_DOWN:
                game.figure.y += 1
                if game.intersects():
                    game.figure.y -= 1
            elif event.key == pygame.K_UP:
                game.figure.rotate()
                while game.intersects():  # !!! изменила if на while, так как возможно потребуется не один поворот,
                    # чтобы перестали пересекаться
                    game.figure.rotate()
    if not running:  # !!! добавила прерывание игрового цикла while, если флаг running = False
        break

    if pygame.time.get_ticks() - last_move_down > fall_speed:
         game.figure.y += 1
         if game.intersects():
            game.figure.y -= 1
            game.freeze()
         last_move_down = pygame.time.get_ticks()

    # перерисовка
    screen.fill(WHITE)
    for y in range(game.height):
        for x in range(game.width):
            if game.field[y][x]:
                # !!! изменила код в строчке ниже, так как ты неправильно использовал функцию pygame.draw.rect
                pygame.draw.rect(screen, game.field[y][x],
                                 (x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE))
                # !!! тонкая окантовка блока фигуры для красоты
                pygame.draw.rect(screen, BLACK,
                                 (x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE), 3)

    shape = game.figure.shape
    for y, row in enumerate(shape):
        for x, cell in enumerate(row):
            if cell:
                # !!! изменила код в строчке ниже, так как ты неправильно использовал функцию pygame.draw.rect
                pygame.draw.rect(screen, game.figure.color,
                                 ((game.figure.x + x) * BLOCK_SIZE, (game.figure.y + y) * BLOCK_SIZE,
                                  BLOCK_SIZE, BLOCK_SIZE))
                # !!! тонкая окантовка блока фигуры для красоты
                pygame.draw.rect(screen, BLACK,
                                 ((game.figure.x + x) * BLOCK_SIZE, (game.figure.y + y) * BLOCK_SIZE,
                                  BLOCK_SIZE, BLOCK_SIZE), 3)

    score_text = font.render(f"Счет: {game.score}", True, BLACK)
    screen.blit(score_text,(10, 10))
    pygame.display.update()  #  !!! не забываем обновлять экран

# к этому моменту прошлый цикл завершился (running = False), но нужно вывести в конце финальный счёт
game_over_text = font.render("GAME OVER", True, BLACK)
game_over = True
while game_over:
    clock.tick(FPS)
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            game_over = False
            break
    if not game_over:
        break
    screen.fill(WHITE)
    screen.blit(game_over_text, (SCREEN_WIDTH // 2 - 80, SCREEN_HEIGHT // 2))
    pygame.display.update()  #  !!! не забываем обновлять экран
